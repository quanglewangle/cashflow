<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Card name" />
    <EditText
        android:id="@+id/inputName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. Barclaycard"
        android:inputType="text" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Statement closing day" />
    <EditText
        android:id="@+id/inputStatementDay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Day of month, 1-31"
        android:inputType="number"
        android:maxLength="2" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Payment due day" />
    <EditText
        android:id="@+id/inputDueDay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Day of month, 1-31"
        android:inputType="number"
        android:maxLength="2" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Months after statement until due" />
    <EditText
        android:id="@+id/inputDueMonthOffset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Usually 1"
        android:inputType="number"
        android:maxLength="1" />

    <CheckBox
        android:id="@+id/checkCarriesBalance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Carries a revolving balance (fixed installment, not paid off each cycle)" />

</LinearLayout>
