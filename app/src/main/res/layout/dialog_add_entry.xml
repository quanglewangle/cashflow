<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <EditText
        android:id="@+id/inputName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Description"
        android:inputType="text" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Category" />
    <Spinner
        android:id="@+id/spinnerCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Type" />
    <Spinner
        android:id="@+id/spinnerItemType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <EditText
        android:id="@+id/inputAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Planned amount"
        android:inputType="numberDecimal" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Day of month (optional)" />
    <EditText
        android:id="@+id/inputDueDay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 15"
        android:inputType="number"
        android:maxLength="2" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Decays by £/week (optional)" />
    <EditText
        android:id="@+id/inputDecayPerWeek"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 100 -- shrinks the estimate as real purchases replace it"
        android:inputType="numberDecimal" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Card (optional -- folds this into that card's payment total instead of the general balance)" />
    <Spinner
        android:id="@+id/spinnerCreditCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
