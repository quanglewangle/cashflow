<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter the actual balance from your bank app. Adding a checkpoint for an existing date replaces it." />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Year" />
    <EditText
        android:id="@+id/inputYear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 2026"
        android:inputType="number"
        android:maxLength="4" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Month (1-12)" />
    <EditText
        android:id="@+id/inputMonth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 6"
        android:inputType="number"
        android:maxLength="2" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Day (1-31)" />
    <EditText
        android:id="@+id/inputDay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 16"
        android:inputType="number"
        android:maxLength="2" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Balance" />
    <EditText
        android:id="@+id/inputBalance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 650.00"
        android:inputType="numberDecimal" />

</LinearLayout>
